# this file documents env vars for model providers
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODELS=openrouter/free,openai/gpt-oss-20b:free
OPENROUTER_SITE_URL=http://localhost:3000

GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
GOOGLE_GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODELS=llama-3.1-8b-instant

EURON_API_KEY=
EURON_BASE_URL=https://api.euron.one/api/v1/euri/chat/completions
EURON_MODELS=gpt-4.1-nano,gpt-4.1-mini,openai/gpt-oss-20b

MODEL_PROVIDER_ORDER=google,openrouter,groq,euron
